# Copy this file to ".env" and fill in your values for local development.
# The .env file is gitignored so your secrets stay local.

# PostgreSQL connection string.
# For a free cloud database, sign up at https://neon.tech and paste its connection string here.
# For a local Postgres install, use: postgresql://postgres:postgres@localhost:5432/little_things
DATABASE_URL=

# Secret used to sign JWT auth tokens (any long random string for local dev).
JWT_SECRET=local-dev-secret-change-me

# Allowed frontend origin(s), comma-separated. Vite dev server default:
CLIENT_ORIGIN=http://localhost:5173
